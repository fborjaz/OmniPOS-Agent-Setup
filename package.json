{
  "name": "gobytel-agent",
  "version": "1.0.0",
  "description": "GoByTel Agent - Servicio de hardware local para el sistema POS GoByTel",
  "main": "src/agent.js",
  "author": "Frank Borja <https://github.com/fborjaz>",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "node src/agent.js",
